# ─────────────────────────────────────────────────────────────
# DATABASE (Prisma)
# Get your connection strings from: https://neon.tech or your own PostgreSQL instance
# DIRECT_URL is used by prisma.config.ts for direct (non-pooled) connections
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION
# Any long, random secret string – used to sign/verify JWT tokens
# Generate one with: openssl rand -base64 32
# Must match AUTH_SECRET in the root .env
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="your-super-secret-jwt-key"

# ─────────────────────────────────────────────────────────────
# SERVER
# Port the Express backend listens on (default: 4000)
# ─────────────────────────────────────────────────────────────
PORT=4000

# ─────────────────────────────────────────────────────────────
# GOOGLE GEMINI AI
# Get your API key from: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
